# Build artifacts
/target/
debug/

# Cargo.lock intentionally excluded: this crate is published as a library.
# If the binary usage ever dominates, revisit.
# https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# Rustfmt backup files
**/*.rs.bk

# MSVC Windows debug info
*.pdb

# Local environment (use .env.example as a template)
.env
.env.local

# Coverage artifacts
/llvm/
*.profraw
/coverage/*.html
/coverage/*.json
/coverage/src/
/coverage/badges/*.svg
!/coverage/badges/flat.svg
lcov.info

# Binary output
/evm-rs
*.tar.gz

# Bytecode files (except the committed sample)
*.bin
!bytecode.bin
